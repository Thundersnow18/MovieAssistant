# ─── Database (PostgreSQL) ───
# Local: postgresql://user:password@localhost:5432/movie_assistant
# Render: Use the Internal Database URL from your Render PostgreSQL dashboard
DATABASE_URL="postgresql://user:password@localhost:5432/movie_assistant"

# ─── Authentication ───
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-in-production"

# ─── TMDB API ───
# Get your free key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ─── Redis Cache (optional — falls back to in-memory if not set) ───
# Render: Use the Internal Redis URL from your Render Redis dashboard
# REDIS_URL=redis://localhost:6379

# ─── Server ───
PORT=5000

# ─── CORS ───
# Set to your deployed frontend URL
# FRONTEND_URL=https://your-app.vercel.app

# ─── Environment ───
NODE_ENV=development
